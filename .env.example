KONG_PROXY_PORT=80
KONG_ADMIN_PORT=8001
KONG_APP_HOST=eduskill.localhost
KONG_AUTH_HOST=auth.localhost

# ─── Zitadel OIDC 配置 ───────────────────────────────────────────────────────
ZITADEL_ISSUER=http://auth.localhost
ZITADEL_INTERNAL_ISSUER=http://auth.localhost
ZITADEL_CLIENT_ID=379285675003936772
# PAT 从文件读取，Docker 部署时自动挂载 zitadel-bootstrap volume
# ZITADEL_SERVICE_PAT_FILE=/zitadel/bootstrap/login-client.pat
ZITADEL_LOGIN_REDIRECT_URI=http://auth-service:3000/auth/callback
ZITADEL_PROJECT_ID=379285558100230148
ZITADEL_DEFAULT_ROLE_KEY=

# ─── 阿里云短信配置 ─────────────────────────────────────────────────────────
# 获取方式：阿里云控制台 → AccessKey 管理
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
# 短信签名名称（需在阿里云控制台申请并通过审核）
ALIYUN_SMS_SIGN_NAME=
# 短信模板 Code（需在阿里云控制台创建并通过审核，模板需包含 ${code} 变量）
ALIYUN_SMS_TEMPLATE_CODE=

# ─── 邀请码配置 ───────────────────────────────────────────────────────────
# 逗号分隔的邀请码列表
INVITE_CODES=
# 是否强制要求邀请码注册（true/false，默认 false）
INVITE_REQUIRED=false
